{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "RISCV-QEMU-Debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/test.elf",
            "args": [],
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "D:/RISCV-none-elf-gcc/xpack-riscv-none-elf-gcc-15.2.0-1-win32-x64/xpack-riscv-none-elf-gcc-15.2.0-1/bin/riscv-none-elf-gdb.exe", 
            // ⚠️ 请确认 bin 目录下确实有这个 riscv-none-embed-gdb.exe 文件
            "miDebuggerServerAddress": "localhost:1234",
            "setupCommands": [
                {
                    "description": "为 gdb 启用整齐打印",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "强制指定架构为 RISC-V 32位",
                    "text": "set arch riscv:rv32",
                    "ignoreFailures": true
                }
            ],
            "logging": { "engineLogging": false }
        }
    ]
}